---
import "../styles/global.css";
import Navbar from "../components/NavbarReact";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/800.css";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Agencia de Marketing Digital. Transformamos tu presencia en redes sociales en ventas reales con estrategias personalizadas y contenido de alto impacto.",
} = Astro.props;
const siteUrl = "https://impactocreativo.ar"; // Ensure valid canonical domain
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
        <meta name="robots" content="index, follow" />
        <meta name="theme-color" content="#0B0B0B" />
        <link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

		<!-- Open Graph / Social Media Meta Tags -->
		<meta property="og:site_name" content="Impacto Creativo" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:locale" content="es_AR" />
        
        <!-- Twitter Card Meta Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        {/* JSON-LD Structured Data for Local Business/Agency */}
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "ProfessionalService",
          "name": "Impacto Creativo",
          "image": `${siteUrl}/favicon.svg`,
          "@id": siteUrl,
          "url": siteUrl,
          "telephone": "+543875709771",
          "priceRange": "$$",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Salta",
            "addressCountry": "AR"
          },
          "openingHoursSpecification": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "09:00",
            "closes": "21:00"
          },
          "sameAs": [
            "https://instagram.com/impactocreativo.ar",
            "https://tiktok.com/@impactocreativo.ar"
          ]
        })} />
	</head>
	<body class="bg-background text-white min-h-screen flex flex-col relative">
		<Navbar client:load />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<FloatingCTA client:idle />
	</body>
</html>
